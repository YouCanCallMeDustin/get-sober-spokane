extends layout

block head
  - var canonicalUrl = 'https://www.getsoberspokane.com/spokane-valley-recovery-resources.html'
  title Addiction Recovery Resources in Spokane Valley, WA | Get Sober Spokane
  meta(name="description" content="Free addiction recovery resources in Spokane Valley, WA. Find treatment programs, sober living, food banks, and support groups near you.")
  script(type="application/ld+json").
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Get Sober Spokane",
      "url": "https://www.getsoberspokane.com",
      "logo": "https://www.getsoberspokane.com/assets/img/logo.png",
      "telephone": "(509) 389-9350",
      "email": "spokanesober@gmail.com",
      "areaServed": {
        "@type": "City",
        "name": "Spokane Valley",
        "addressRegion": "WA"
      }
    }

block content

  header.bg-primary.text-white.py-5(style="margin-top: 76px;")
    .container.px-4.px-lg-5
      .row.justify-content-center
        .col-lg-8.text-center
          h1.display-5.fw-bold Free Recovery Resources in Spokane Valley, WA
          p.lead.mt-3 Connecting Spokane Valley residents with free, local addiction recovery services.

  section.page-section
    .container.px-4.px-lg-5
      .row.justify-content-center
        .col-lg-8
          p.lead.mt-4
            | Spokane Valley is home to a growing recovery community. Whether you're just starting your journey or looking for ongoing support, Get Sober Spokane connects you with free resources right here in the Valley — from treatment referrals and sober living homes to food banks and AA/NA meetings.

          // Treatment Resources
          h2.mt-5
            i.bi.bi-heart-pulse.text-primary.me-2
            | Treatment Resources
          p Find addiction treatment programs in and near Spokane Valley, including inpatient, outpatient, and medication-assisted treatment options.
          ul
            li Valley Hope Treatment — Outpatient counseling and group therapy
            li Spokane Valley Partners — Referrals to local treatment programs
            li SAMHSA Helpline: 1-800-662-4357 (free, 24/7)
          a.btn.btn-outline-primary(href="/addiction-treatments-support.html" onclick="gtag('event', 'resources_click', {event_category: 'engagement', event_label: 'treatment_valley'})")
            i.bi.bi-arrow-right.me-2
            | Browse Treatment Programs

          // Shelter & Housing
          h2.mt-5
            i.bi.bi-house.text-primary.me-2
            | Shelter &amp; Housing
          p Sober living homes and emergency shelter options available to Spokane Valley residents in recovery.
          ul
            li Valley YMCA Emergency Shelter — Short-term housing assistance
            li Catholic Charities Eastern WA — Transitional housing programs
            li Salvation Army Valley Corps — Emergency shelter referrals
          a.btn.btn-outline-primary(href="/shelter-housing.html" onclick="gtag('event', 'resources_click', {event_category: 'engagement', event_label: 'housing_valley'})")
            i.bi.bi-arrow-right.me-2
            | Find Housing Resources

          // Sober Activities
          h2.mt-5
            i.bi.bi-people.text-primary.me-2
            | Sober Activities
          p Stay connected with a sober community through local events and activities in Spokane Valley.
          ul
            li Valley 12-Step Club — Daily AA and NA meetings
            li Spokane Valley YMCA — Fitness, swimming, and wellness programs
            li Liberty Lake Regional Park — Outdoor recreation and community events
          a.btn.btn-outline-primary(href="/community-engagement-sober-activities.html" onclick="gtag('event', 'resources_click', {event_category: 'engagement', event_label: 'activities_valley'})")
            i.bi.bi-arrow-right.me-2
            | Explore Sober Activities

          // Get Help Now
          .mt-5.p-4.bg-light.rounded-3
            h2.h4
              i.bi.bi-telephone-fill.text-danger.me-2
              | Get Help Now
            p If you or someone you know needs immediate help with addiction in Spokane Valley:
            ul.mb-3
              li
                strong Crisis Line:
                |  988 (Suicide &amp; Crisis Lifeline)
              li
                strong SAMHSA:
                |  1-800-662-4357
              li
                strong Local:
                |  (509) 389-9350
            a.btn.btn-primary.me-2(href="/resource-directory.html" onclick="gtag('event', 'resources_click', {event_category: 'engagement', event_label: 'all_resources_valley'})")
              i.bi.bi-list-ul.me-2
              | All Resources
            a.btn.btn-danger(href="tel:+19888" onclick="gtag('event', 'phone_click', {event_category: 'contact', event_label: '988_valley'})")
              i.bi.bi-telephone.me-2
              | Call 988
