      "publisher": {
        "@type": "Organization",
        "name": "Get Sober Spokane",
        "logo": {
          "@type": "ImageObject",
          "url": "https://www.getsoberspokane.com/assets/img/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://www.getsoberspokane.com/blog/medication-assisted-treatment-spokane.html"
      }
    }
  script(type="application/ld+json").
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Is MAT just trading one addiction for another?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Addiction is an uncontrollable craving even in the face of negative consequences. MAT involves prescribed, stable doses of medication that reduce cravings and eliminate the 'high,' allowing patients to regain stability and function in their daily lives."
          }
        },
        {
          "@type": "Question",
          "name": "Does Spokane Apple Health (Medicaid) cover Suboxone?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Washington Apple Health (Medicaid) completely covers Medication-Assisted Treatment, including consultations and the prescriptions for Suboxone, Methadone, and Vivitrol."
          }
        },
        {
          "@type": "Question",
          "name": "How do I find a Suboxone doctor in Spokane?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Many local providers like CHAS Health, Ideal Option, and Frontier Behavioral Health offer Suboxone. You can also use the SAMHSA treatment locator or our local resource directory to find certified MAT providers."
          }
