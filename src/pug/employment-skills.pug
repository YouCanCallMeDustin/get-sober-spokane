extends layout.pug

block meta
    meta(name="description" content="Job training and employment resources for individuals in recovery in Spokane, WA. Build new skills and find career opportunities to support your sober life.")

    script(type="application/ld+json").
      {
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "name": "Employment & Skills Training Spokane, WA",
        "description": "Discover job placement, skills training, and workforce development resources in Spokane, WA.",
        "url": "https://www.getsoberspokane.com/employment-skills.html",
        "about": {
          "@type": "Thing",
          "name": "Workforce Development and Employment Services"
        }
      }

block content
    // Hero Section
    // Hero Section
    header.page-hero
      .container.px-4.px-lg-5
        h1 Employment & Skills Training
        p.lead Workforce development and job placement resources in Spokane, WA.
        .hero-badges
          .hero-badge
            i.bi.bi-briefcase
            span Job Placement
          .hero-badge
            i.bi.bi-tools
            span Skills Training

    // Main Content
    section.page-section
      .container.px-4.px-lg-5
        .row.justify-content-center
          .col-lg-10
            h2.text-primary.mt-0 Employment & Skills Management in Spokane
            p Spokane offers a robust network of employment and workforce development resources for adults, youth, seniors, and businesses. Services include job placement, resume help, apprenticeships, and employer support.
            h3.mt-5 Employment Services
            p.text-muted
              | Local organizations help job seekers find employment, prepare resumes, and connect with hiring events.
            .table-responsive
              table.table.table-bordered.table-striped.mt-3
                thead
                  tr
                    th Organization
                    th Address
                    th Services
                    th Website
                tbody
                  tr
                    td Express Employment Professionals
                    td Spokane, WA (address not specified)
                    td Staffing, job placement (full/part-time, temp)
                    td: a(href='https://expresspros.com', target='_blank') expresspros.com
                  tr
                    td WorkSource Spokane
                    td Multiple locations
                    td Career center, job placement, resume help, hiring events
                    td: a(href='https://worksourcespokane.com', target='_blank') worksourcespokane.com
                  tr
                    td WorkSourceWA Job Search Portal
                    td Online
                    td Job listings, resume builder, interview prep
                    td: a(href='https://seeker.worksourcewa.com', target='_blank') seeker.worksourcewa.com
                  tr
                    td Resource Center of Spokane County
                    td Spokane, WA (address not specified)
                    td Social services, employment support
                    td: a(href='https://spokaneresourcecenter.org', target='_blank') spokaneresourcecenter.org
            h3.mt-5 Skills Training & Development
            p.text-muted
              | Training programs and apprenticeships help build skills for sustainable careers and connect job seekers to new opportunities.
            .table-responsive
              table.table.table-bordered.table-striped.mt-3
                thead
                  tr
                    th Organization
                    th Address
                    th Services
                    th Website
                tbody
                  tr
                    td Spokane Workforce Council
                    td Spokane, WA (address not specified)
                    td Apprenticeships, hiring events, resume/job search support
                    td: a(href='https://spokaneworkforce.org', target='_blank') spokaneworkforce.org
                  tr
                    td Next Generation Zone
                    td Spokane, WA (address not specified)
                    td Career center for young adults, education, skills training
                    td: a(href='https://nextgenzone.org', target='_blank') nextgenzone.org
                  tr
                    td Spokane Community College - Community Resource Directory
                    td Spokane, WA (address not specified)
                    td Work-training for seniors, education resources
                    td: a(href='https://sfcc.spokane.edu', target='_blank') sfcc.spokane.edu
                  tr
                    td Affiliated Connection Sites
                    td Multiple locations in Spokane County
                    td Workforce services at 20+ locations
                    td: a(href='https://nextgenzone.org', target='_blank') nextgenzone.org
            h3.mt-5 Employer Support
            p.text-muted
              | Employers can access recruitment, training, and workforce development services to build skilled teams.
            .table-responsive
              table.table.table-bordered.table-striped.mt-3
                thead
                  tr
                    th Organization
                    th Address
                    th Services
                    th Website
                tbody
                  tr
                    td Talent Solutions by WorkSource Spokane
                    td Spokane, WA (address not specified)
                    td Business consulting, recruitment, workforce strategies
                    td: a(href='https://worksourcespokane.com/employers', target='_blank') worksourcespokane.com/employers
                  tr
                    td Impact Washington
                    td Spokane, WA (address not specified)
                    td Consulting, training, funding for manufacturers
                    td: a(href='https://www.impactwashington.org', target='_blank') impactwashington.org
                  tr
                    td Spokane Valley Chamber of Commerce - Workforce Training & Recruitment
                    td Spokane Valley, WA
                    td Training, recruitment, access to educational institutions
                    td: a(href='https://spokanevalleywa.gov', target='_blank') spokanevalleywa.gov
            h3.mt-5 Additional Resources
            ul
              li
                strong Workforce Wednesday:
                |  Weekly segment on Fox 28 at 7:00 AM with updates on workforce services and events (
                a(href='https://bitly.spokaneworkforce.org', target='_blank') bitly.spokaneworkforce.org
                | ).
              li
                strong workforceNERD. thePODCAST.:
                |  Video podcast on workforce development, available through Spokane Workforce Council channels.
              li
                strong Spokane’s Educational Institutions:
                |  18 universities and colleges in the region provide a talent pool and training programs (
                a(href='https://spokanevalleywa.gov', target='_blank') spokanevalleywa.gov
                | ).
            h3.mt-5 Access & Support
            ul
              li Call Washington 2-1-1 at (877) 211-9274 for referrals to employment, training, and community services.
              li Explore the
                a(href='https://thefigtree.org', target='_blank') Fig Tree Resource Guide
                |  for a comprehensive directory of employment and workforce resources.
              li Use the
                a(href='https://www.google.com/maps/d/u/0/viewer?mid=1QwQwQwQwQwQwQwQwQwQwQwQwQwQwQwQw&ll=47.6588%2C-117.4260&z=12', target='_blank') Spokane Resource Google Map
                |  to find employment and training services.
              li Check
                a(href='https://spokaneworkforce.org', target='_blank') spokaneworkforce.org
                |  for upcoming hiring events and workforce news.
    // Call to Action
    section.page-section.bg-primary.text-white.text-center
      .container.px-4.px-lg-5
        h2.mb-4 Need Help with Employment or Training?
        p.mb-4 Call Washington 2-1-1 or connect with a local employment resource for immediate support.
        a.btn.btn-light.btn-xl(href='index.html#contact') Contact Us 