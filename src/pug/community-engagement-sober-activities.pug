block content
    //- Hero Section
    header.page-hero
      .container.px-4.px-lg-5
        h1 Community Engagement & Sober Activities in Spokane, WA
        p.lead Alcohol-free social events, active recovery groups, and meaningful community connection.
        .hero-badges
          .hero-badge
            i.bi.bi-calendar-heart
            span Active Events
          .hero-badge
            i.bi.bi-people
            span Supportive Community

    //- Main Content
    section.page-section
      .container.px-4.px-lg-5
        .row.justify-content-center
          .col-lg-10
            h2.text-primary.mt-0 Sober Activities & Community Engagement in Spokane
            p Spokane offers a growing network of sober events, active community groups, and alcohol-free activities for individuals in recovery, those exploring sobriety, and anyone seeking healthy social opportunities. Building community connection is one of the strongest foundations for lasting recovery.

            //- Upcoming Events Section
            .mt-5
              h3.text-primary Upcoming Sober Events in Spokane
              .alert.alert-info.shadow-sm.border-0.mb-4(style="border-radius: 12px;")
                i.bi.bi-info-circle-fill.me-2
                | Events are updated regularly. Join our #[a.alert-link(href='community-forum.html') community forum] to stay informed about the latest sober activities in Spokane.

              .row.gx-4.gy-4
                .col-md-6
                  .card.h-100.shadow-sm.border-0(style="border-radius: 15px; overflow: hidden;")
                    .card-body.p-4
                      .d-flex.align-items-center.mb-3
                        .feature.bg-primary.bg-gradient.text-white.rounded-3.me-3.p-2
                          i.bi.bi-calendar-event(style="font-size: 1.5rem;")
                        div
                          h5.card-title.mb-0 Spokane Sober Community Meetup
                          small.text-muted Monthly | 6:00 PM – 8:00 PM
                      p.card-text.text-muted A free monthly community gathering for people in recovery. Share stories, build connections, and enjoy fellowship.
                      .mt-auto
                        span.badge.bg-light.text-primary.px-3.py-2 Community Event

                .col-md-6
                  .card.h-100.shadow-sm.border-0(style="border-radius: 15px; overflow: hidden;")
                    .card-body.p-4
                      .d-flex.align-items-center.mb-3
                        .feature.bg-success.bg-gradient.text-white.rounded-3.me-3.p-2
                          i.bi.bi-walk(style="font-size: 1.5rem;")
                        div
                          h5.card-title.mb-0 Sober Hike – Centennial Trail
                          small.text-muted Bi-Monthly | 9:00 AM – 12:00 PM
                      p.card-text.text-muted A free group hike along the Centennial Trail for people in recovery and their supporters. All fitness levels welcome.
                      .mt-auto
                        span.badge.bg-light.text-success.px-3.py-2 Outdoor Activity

                .col-md-6
                  .card.h-100.shadow-sm.border-0(style="border-radius: 15px; overflow: hidden;")
                    .card-body.p-4
                      .d-flex.align-items-center.mb-3
                        .feature.bg-warning.bg-gradient.text-dark.rounded-3.me-3.p-2
                          i.bi.bi-cup-hot(style="font-size: 1.5rem;")
                        div
                          h5.card-title.mb-0 Recovery & Coffee
                          small.text-muted Monthly | 10:00 AM – 11:30 AM
                      p.card-text.text-muted Casual coffee meetup in a safe, supportive space. Connect with others on the recovery journey.
                      .mt-auto
                        span.badge.bg-light.text-warning.px-3.py-2 Social Gathering

                .col-md-6
                  .card.h-100.shadow-sm.border-0(style="border-radius: 15px; overflow: hidden;")
                    .card-body.p-4
                      .d-flex.align-items-center.mb-3
                        .feature.bg-info.bg-gradient.text-white.rounded-3.me-3.p-2
                          i.bi.bi-chat-dots(style="font-size: 1.5rem;")
                        div
                          h5.card-title.mb-0 Online Recovery Support Chat
                          small.text-muted Every Tuesday | 7:00 PM – 8:00 PM
                      p.card-text.text-muted Free weekly live chat for people in recovery. Join from anywhere in the Spokane area via our website.
                      .mt-auto
                        a.badge.bg-light.text-info.px-3.py-2.text-decoration-none(href='chat.html') Join Online Chat

            //- Sober Social Events
            h3.mt-5 Sober Social Events
            p.text-muted Enjoy structured, alcohol-free gatherings designed for fun and connection in a safe, welcoming environment.
            .table-responsive
              table.table.table-bordered.table-striped.mt-3
                thead.table-dark
                  tr
                    th Organization/Event
                    th Details
                    th Location
                    th Contact/Website
                tbody
                  tr
                    td Diversion Events
                    td Mocktail parties, DJ music, dancing, food. Monthly events, no alcohol allowed.
                    td 22 Rooms, 1011 W First Ave, Spokane, WA 99201
                    td: a(href='https://www.eventbrite.com/o/diversion-events-72839301103', target='_blank', rel='noopener') Eventbrite
                  tr
                    td Reclaim Project Recovery Flannel Gala
                    td Annual fundraiser and celebration for men in recovery, community engagement.
                    td True Hope Church, Spokane, WA
                    td: a(href='https://reclaimprojectnw.org', target='_blank', rel='noopener') reclaimprojectnw.org
                  tr
                    td Recovery Cafe Spokane – Community Meals
                    td Free community meals and social connection for members committed to recovery.
                    td 715 W Sprague Ave, Spokane, WA 99201
                    td: a(href='https://recoverycafespokane.org', target='_blank', rel='noopener') recoverycafespokane.org

            //- Active Sober Community Activities
            h3.mt-5 Active Sober Community Activities
            p.text-muted Join group fitness, outdoor adventures, and skill-building activities in a supportive, substance-free environment.
            .table-responsive
              table.table.table-bordered.table-striped.mt-3
                thead.table-dark
                  tr
                    th Organization
                    th Activities
                    th Location
                    th Contact/Website
                tbody
                  tr
                    td Reclaim Project Recovery
                    td Strength training, yoga, running, hiking, biking, MMA, paddle boarding, recovery classes
                    td 1804 W Broadway, Spokane, WA 99201
                    td: a(href='https://reclaimprojectnw.org', target='_blank', rel='noopener') reclaimprojectnw.org
                  tr
                    td Centennial Trail – Spokane
                    td 37-mile trail for walking, biking, running; scenic and alcohol-free
                    td Multiple access points across Spokane
                    td: a(href='https://visitspokane.com', target='_blank', rel='noopener') visitspokane.com
                  tr
                    td Spokane Parks & Recreation
                    td Hiking, swimming, sports fields, fitness activities at 90+ parks
                    td Various locations across Spokane
                    td: a(href='https://my.spokanecity.org/recreation/', target='_blank', rel='noopener') spokanecity.org/recreation

            //- Community Sports Leagues
            h3.mt-5 Community Sports Leagues
            p.text-muted Get active and meet new people in sober-friendly sports leagues and tournaments.
            .table-responsive
              table.table.table-bordered.table-striped.mt-3
                thead.table-dark
                  tr
                    th Organization/Event
                    th Details
                    th Location
                    th Contact/Website
                tbody
                  tr
                    td City of Spokane Parks & Recreation
                    td Adult softball, flag football, volleyball; 6-week seasons, 12-game guarantee
                    td Dwight Merkel Sports Complex, Franklin Park Softball Complex
                    td: a(href='https://my.spokanecity.org/recreation/sports/', target='_blank', rel='noopener') spokanecity.org/recreation/sports
                  tr
                    td Spokane Summer Classic
                    td Annual 7v7 adult soccer tournament, July event
                    td Plante's Ferry Complex, Spokane Valley, WA
                    td: a(href='https://spokanesummerclassic.com', target='_blank', rel='noopener') spokanesummerclassic.com
                  tr
                    td Hub Sports Center – Leagues
                    td Basketball, volleyball, pickleball, indoor soccer; year-round leagues
                    td 19619 E Cataldo Ave, Liberty Lake, WA 99016
                    td: a(href='https://hubsportscenter.org', target='_blank', rel='noopener') hubsportscenter.org

            //- Recovery-Focused Support Groups (on this page)
            h3.mt-5 Recovery-Focused Community Groups
            p.text-muted Connect with peer-led groups for support, accountability, and fellowship in recovery.
            .table-responsive
              table.table.table-bordered.table-striped.mt-3
                thead.table-dark
                  tr
                    th Organization
                    th Details
                    th Location
                    th Contact/Website
                tbody
                  tr
                    td Alcoholics Anonymous (AA) – Spokane
                    td Open/closed/speaker meetings; peer support for alcohol recovery
                    td Multiple locations (see website)
                    td: a(href='https://aaspokane.org', target='_blank', rel='noopener') aaspokane.org
                  tr
                    td Narcotics Anonymous (NA) – Spokane Area
                    td Peer support for drug recovery; meetings across Spokane
                    td Multiple locations
                    td: a(href='https://na.org', target='_blank', rel='noopener') na.org
                  tr
                    td Al-Anon/Alateen – Spokane
                    td Support for families and teens affected by addiction
                    td 1700 W 7th Ave, Suite 100, Spokane, WA 99204
                    td: a(href='tel:+15094562125') (509) 456-2125
                  tr
                    td Recovery Cafe Spokane – Recovery Circles
                    td Peer-led support circles, career mentoring, community meals
                    td 715 W Sprague Ave, Spokane, WA 99201
                    td: a(href='https://recoverycafespokane.org', target='_blank', rel='noopener') recoverycafespokane.org
                  tr
                    td Peer Spokane
                    td Peer recovery coaching, mental health support, employment coaching
                    td 1222 N Post St, Spokane, WA 99201
                    td: a(href='https://peerspokane.org', target='_blank', rel='noopener') peerspokane.org

            //- General Community Engagement
            h3.mt-5 General Community Engagement
            p.text-muted Explore alcohol-free parks, cultural events, and volunteer opportunities for meaningful community connection.
            .table-responsive
              table.table.table-bordered.table-striped.mt-3
                thead.table-dark
                  tr
                    th Activity/Organization
                    th Details
                    th Location
                    th Contact/Website
                tbody
                  tr
                    td Riverfront Park
                    td Urban waterfall, walking paths, playgrounds, seasonal events
                    td Downtown Spokane
                    td: a(href='https://visitspokane.com', target='_blank', rel='noopener') visitspokane.com
                  tr
                    td Spokane Public Library – Programs
                    td Free workshops, book clubs, computer access, community meeting spaces
                    td Multiple branches across Spokane
                    td: a(href='https://spokanelibrary.org', target='_blank', rel='noopener') spokanelibrary.org
                  tr
                    td Volunteer Spokane
                    td Community service with Second Harvest, Catholic Charities, Habitat for Humanity
                    td Various locations
                    td: a(href='https://volunteerspokane.org', target='_blank', rel='noopener') volunteerspokane.org
                  tr
                    td Spokane Art & Culture
                    td Museums, galleries, concerts, First Friday events (alcohol-free options available)
                    td Various locations
                    td: a(href='https://visitspokane.com', target='_blank', rel='noopener') visitspokane.com

            h3.mt-5 Access & Support
            ul
              li Call Washington 2-1-1 at #[a(href='tel:+18772119274') (877) 211-9274] for referrals to community events, support groups, and sober activities.
              li Explore the #[a(href='https://thefigtree.org', target='_blank', rel='noopener') Fig Tree Resource Guide] for a comprehensive directory of community resources.
              li Visit #[a(href='https://www.meetup.com', target='_blank', rel='noopener') Meetup.com] for groups like Spokane Young and Active or Spokane Canoe and Kayak Club.
              li Browse our full #[a(href='/resource-directory.html') Resource Directory] for all verified Spokane recovery resources.

    //- Call to Action
    section.page-section.bg-primary.text-white.text-center
      .container.px-4.px-lg-5
        h2.mb-4 Looking for Sober Social Opportunities?
        p.mb-4 Call Washington 2-1-1 or explore local events and groups for alcohol-free fun and connection.
        a.btn.btn-light.btn-xl(href='index.html#contact') Contact Us