extends layout.pug

block meta
    meta(name="description" content="Find 30+ addiction treatment centers and peer-led support groups in Spokane, WA. Detox, inpatient rehab, outpatient programs, AA, NA, SMART Recovery, and Celebrate Recovery meeting schedules.")

    script(type="application/ld+json").
      {
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "name": "Addiction Treatment Centers & Support Groups in Spokane, WA",
        "description": "Comprehensive directory of 30+ addiction treatment centers and peer-led support groups in Spokane, WA including detox, residential, outpatient, AA, NA, and faith-based recovery programs.",
        "url": "https://www.getsoberspokane.com/addiction-treatments-support.html",
        "about": {
          "@type": "Thing",
          "name": "Substance Abuse Treatment and Recovery Support"
        }
      }

block content
    //- Hero Section
    header.page-hero
      .container.px-4.px-lg-5
        h1 Addiction Treatment & Support Groups in Spokane, WA
        p.lead Professional treatment centers and peer-led recovery support networks across Spokane.
        .hero-badges
          .hero-badge
            i.bi.bi-capsule
            span 15+ Treatment Centers
          .hero-badge
            i.bi.bi-people
            span 15+ Support Groups

    //- Main Content
    section.page-section
      .container.px-4.px-lg-5
        .row.justify-content-center
          .col-lg-10
            h2.text-primary.mt-0 Addiction Treatment Centers in Spokane
            p Spokane offers a wide range of addiction treatment centers providing evidence-based care from medical detox and residential programs to outpatient therapy, medication-assisted treatment (MAT), and specialized youth services. Many centers accept Medicaid, private insurance, and offer sliding-scale fees.

