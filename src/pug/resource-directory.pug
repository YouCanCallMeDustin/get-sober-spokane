extends layout.pug

block content
    // Emergency Banner
    section.emergency-banner.bg-danger.text-white.py-3.mt-5.pt-5
        .container.px-4.px-lg-5
            .row.align-items-center
                .col-md-8
                    h5.mb-0
                        i.bi.bi-exclamation-triangle.me-2
                        | Need immediate help? Call the National Suicide Prevention Lifeline: 988 or 1-800-273-8255
                .col-md-4.text-md-end
                    a.btn.btn-light.btn-sm(href='tel:988')
                        i.bi.bi-telephone.me-1
                        | Call Now

    // Search Section
    section.search-section.py-5
        .container.px-4.px-lg-5
            .row.justify-content-center
                .col-lg-10
                    .text-center.mb-4
                        h1.display-4.fw-bold Find Recovery Resources
                        p.lead Find shelters, treatment centers, support groups, and more in the Spokane area
                    .filter-card
                        .row.g-3
                            .col-md-12
                                .input-group
                                    input#resourceSearch.form-control.search-input(type='text', placeholder='Search for shelters, treatment centers, food banks, support groups...')
                                    button.btn.btn-primary.search-btn(type='button')
                                        i.bi.bi-search
                                        |  Search
                        .row.mt-3
                            .col-md-4
                                select#categoryFilter.form-select.filter-select
                                    option(value='all') All Categories
                                    option(value='shelter') Shelters
                                    option(value='food') Food Banks
                                    option(value='treatment') Treatment Centers
                                    option(value='support') Support Groups
                                    option(value='medical') Medical & Mental Health
                                    option(value='employment') Employment & Training
                                    option(value='legal') Legal & Advocacy
                                    option(value='transportation') Transportation
                                    option(value='ministry') Ministry & Spiritual Support
                            .col-md-4
                                select#availabilityFilter.form-select.filter-select
                                    option(value='all') All Availability
                                    option(value='available') Available
                                    option(value='limited') Limited
                                    option(value='full') Full
                            .col-md-4
                                select#sortResources.form-select.filter-select
                                    option(value='relevance') Sort By
                                    option(value='name') Name
                                    option(value='rating') Rating
                                    option(value='distance') Distance

    // Resource Results
    section#resourceDirectory.page-section
        .container.px-4.px-lg-5
            .row
                .col-12
                    h2.text-center.mb-4 Recovery Resources in Spokane
                    p.text-center.text-muted.mb-5 Find the help you need with our comprehensive directory of recovery resources
            
            // Results Container
            #resourceResults.row.g-4

    // Emergency Help Section
    section#emergency-help.page-section.bg-danger.text-white
        .container.px-4.px-lg-5
            .row.justify-content-center
                .col-lg-12
                    .text-center.mb-5
                        h2.display-4.fw-bold
                            i.bi.bi-exclamation-triangle.me-3
                            | Emergency Help
                        p.lead.mb-0 If you're in crisis or need immediate assistance, use these resources:
                        p.small.opacity-75 Available 24/7 • Confidential • Free
                    
                    // Emergency Contact Cards
                    #emergencyHelp.row.g-4.justify-content-center
                        .col-md-6.col-lg-4
                            .card.emergency-card.crisis-card.h-100
                                .card-body.text-center
                                    i.bi.bi-telephone-fill.fs-1.text-danger.mb-3
                                    h5.card-title Recovery Resource Directory Spokane, WA | Comprehensive Addiction Treatment & Supportne, WA | Comprehensive Addiction Treatment & Supportne, WA | Comprehensive Addiction Treatment & Supportne, WA | Comprehensive Addiction Treatment & Supportne, WA | Comprehensive Addiction Treatment & Supportne, WA | Comprehensive Addiction Treatment & Supportntion
                                    p.card-text 24/7 free and confidential support for people in distress
                                    button.btn.btn-danger.btn-lg.w-100(data-contact='crisis')
                                        i.bi.bi-telephone.me-2
                                        | Call 988
                        .col-md-6.col-lg-4
                            .card.emergency-card.substance-card.h-100
                                .card-body.text-center
                                    i.bi.bi-capsule.fs-1.text-primary.mb-3
                                    h5.card-title Substance Use Help
                                    p.card-text Treatment referral and recovery support
                                    button.btn.btn-primary.btn-lg.w-100(data-contact='substance')
                                        i.bi.bi-telephone.me-2
                                        | Call SAMHSA
                        .col-md-6.col-lg-4
                            .card.emergency-card.local-card.h-100
                                .card-body.text-center
                                    i.bi.bi-geo-alt-fill.fs-1.text-success.mb-3
                                    h5.card-title Local Help
                                    p.card-text Spokane area crisis intervention services
                                    button.btn.btn-success.btn-lg.w-100(data-contact='local')
                                        i.bi.bi-telephone.me-2
                                        | Call Local
                    
                    // Additional Emergency Resources
                    .row.mt-5.g-4.justify-content-center
                        .col-md-6.col-lg-4
                            .card.emergency-card.domestic-card.h-100
                                .card-body.text-center
                                    i.bi.bi-shield-fill.fs-1.text-warning.mb-3
                                    h5.card-title Domestic Violence
                                    p.card-text Support for domestic violence situations
                                    button.btn.btn-warning.btn-lg.w-100(data-contact='domestic')
                                        i.bi.bi-telephone.me-2
                                        | Call Hotline
                        .col-md-6.col-lg-4
                            .card.emergency-card.youth-card.h-100
                                .card-body.text-center
                                    i.bi.bi-chat-fill.fs-1.text-info.mb-3
                                    h5.card-title Text Support
                                    p.card-text Crisis support via text message for immediate help
                                    button.btn.btn-info.btn-lg.w-100(data-contact='youth')
                                        i.bi.bi-chat.me-2
                                        | Text HOME to 741741

    // Quick Actions
    section.page-section.bg-primary
        .container.px-4.px-lg-5
            .row.justify-content-center
                .col-lg-8.text-center
                    h2.text-white.mb-4 Additional Resources
                    .row.g-3
                        .col-md-4
                            a.btn.btn-light.btn-lg.w-100(href='map.html')
                                i.bi.bi-map.me-2
                                | View Map
                        .col-md-4
                            a.btn.btn-light.btn-lg.w-100(href='index.html#contact')
                                i.bi.bi-envelope.me-2
                                | Contact Us
                        .col-md-4
                            a.btn.btn-light.btn-lg.w-100(href='#quickHelp')
                                i.bi.bi-shield-check.me-2
                                | Quick Help

    // Quick Help Section
    section#quickHelp.page-section.bg-light
        .container.px-4.px-lg-5
            .row.justify-content-center
                .col-lg-12
                    .text-center.mb-5
                        h2.display-5.fw-bold Quick Help Tools
                        p.lead.text-muted Additional resources and tools to support your recovery journey
                    
                    #quickHelp.row.g-4.justify-content-center
                        .col-md-6.col-lg-4
                            .card.h-100.shadow-sm
                                .card-body.text-center
                                    i.bi.bi-shield-check.fs-1.text-success.mb-3
                                    h5.card-title Safe Exit
                                    p.card-text If you need to quickly leave this page for safety reasons, click the button below.
                                    button.btn.btn-outline-success.btn-lg.w-100(onclick="window.open('https://www.google.com', '_blank')")
                                        i.bi.bi-box-arrow-up-right.me-2
                                        | Safe Exit
                        .col-md-6.col-lg-4
                            .card.h-100.shadow-sm
                                .card-body.text-center
                                    i.bi.bi-geo-alt.fs-1.text-primary.mb-3
                                    h5.card-title Find Nearest Help
                                    p.card-text Get directions to the nearest emergency services or treatment centers.
                                    button.btn.btn-outline-primary.btn-lg.w-100(onclick="findNearestHelp()")
                                        i.bi.bi-map.me-2
                                        | Find Help
                        .col-md-6.col-lg-4
                            .card.h-100.shadow-sm
                                .card-body.text-center
                                    i.bi.bi-calendar-check.fs-1.text-info.mb-3
                                    h5.card-title Recovery Resources
                                    p.card-text Access our comprehensive directory of recovery resources and support services.
                                    a.btn.btn-outline-info.btn-lg.w-100(href="#resourceDirectory" onclick="gtag('event', 'resources_click', {event_category: 'engagement', event_label: 'directory_footer'})")
                                        i.bi.bi-list.me-2
                                        | Browse Resources

block scripts
    // Resource Directory JS
    script(src='js/resource-directory.js')
    // Emergency Help JS
    script(src='js/emergency-help.js')
    // Feedback System JS
    script(src='js/feedback-system.js')
    // SimpleLightbox plugin JS
    script(src='https://cdnjs.cloudflare.com/ajax/libs/SimpleLightbox/2.1.0/simpleLightbox.min.js')
    // Core theme JS
    script(src='js/scripts.js')
    script.
      function findNearestHelp() {
        if (navigator.geolocation) {
          navigator.geolocation.getCurrentPosition(function(position) {
            const lat = position.coords.latitude;
            const lng = position.coords.longitude;
            window.open(`https://www.google.com/maps/search/emergency+help/@${lat},${lng},12z`, '_blank');
          }, function() {
            window.open('https://www.google.com/maps/search/emergency+help+Spokane', '_blank');
          });
        } else {
          window.open('https://www.google.com/maps/search/emergency+help+Spokane', '_blank');
        }
      }
