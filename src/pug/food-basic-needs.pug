extends layout.pug

block meta
    meta(name="description" content="Access food banks, clothing, and basic needs resources in Spokane, WA. We connect you with local services providing essential support during your recovery.")

    script(type="application/ld+json").
      {
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "name": "Food Banks & Basic Needs Assistance Spokane, WA",
        "description": "Find free food, clothing, hygiene products, and other essentials in Spokane, WA. This guide connects you to food banks, pantries, and community resources.",
        "url": "https://www.getsoberspokane.com/food-basic-needs.html",
        "about": {
          "@type": "Thing",
          "name": "Food Security and Basic Needs Services"
        }
      }

block content
    // Hero Section
    // Hero Section
    header.page-hero
      .container.px-4.px-lg-5
        h1 Food & Basic Needs Assistance
        p.lead Nutritious food and essential support for individuals and families.
        .hero-badges
          .hero-badge
            i.bi.bi-basket
            span Food Banks
          .hero-badge
            i.bi.bi-shield-heart
            span Daily Needs

    // Main Content
    section.page-section
      .container.px-4.px-lg-5
        .row.justify-content-center
          .col-lg-10
            h2.text-primary.mt-0 Food Banks and Pantries
            p Spokane is home to a variety of food banks and pantries that provide free groceries and basic necessities to anyone in need. Many locations also offer clothing, hygiene products, and utility assistance.
            .table-responsive
              table.table.table-bordered.table-striped.mt-3
                thead
                  tr
                    th Organization
                    th Address
                    th Hours
                    th Notes
                tbody
                  tr
                    td Free Little Food Pantry
                    td Spokane, WA 99205
                    td Open 24/7
                    td Community-based, always open
                  tr
                    td Second Harvest Inland Northwest
                    td 1234 E Front Ave, Spokane, WA 99202
                    td Mon-Fri 8:00 AM - 4:30 PM (Fri until 12:00 PM)
                    td Major food bank, no appointment needed
                  tr
                    td Serve Spokane
                    td 8303 B, N Division St, Spokane, WA 99208
                    td Tue/Thu 12:30-2:30 PM, Sat 9:00-11:30 AM
                    td May require proof of address
                  tr
                    td Better Living Center
                    td 25 E North Foothills Dr, Spokane, WA 99207
                    td Tue 9:00-11:30 AM, 1:00-3:30 PM; Thu 9:00 AM-12:30 PM
                    td Food & community services
                  tr
                    td Salvation Army - Food Distribution Center
                    td 204 E Indiana Ave, Spokane, WA 99207
                    td Mon-Fri 9:00 AM-4:15 PM
                    td Serves 1,500 families/month
                  tr
                    td Feed Spokane
                    td 1114 N Fancher Rd STE 109, Spokane Valley, WA 99212
                    td Not listed
                    td Food rescue & distribution
                  tr
                    td Our Place Spokane
                    td 1509 W College Ave, Spokane, WA 99201
                    td Wed 3:30-6 PM, Thu 10 AM-12:30 PM, Last Sat 10 AM-12:30 PM
                    td Food, clothing, hygiene, utilities, bus passes
                  tr
                    td Salvation Army - Our Food Bank (Temporary)
                    td 203 E Nora Avenue, Spokane, WA 99027
                    td Mon-Fri 10:00 AM-3:00 PM
                    td Temporary location, large distribution
            h3.mt-5 Additional Food Resources
            p.text-muted
              | In addition to food banks, Spokane offers mobile meal programs and government assistance for food insecurity:
            ul
              li
                strong Second Harvest Mobile Market:
                |  Free produce, meats, and groceries at rotating locations. No appointment needed. Check their website for the next event.
              li
                strong Grad & Go Meals:
                |  Free grab-and-go meals for children and teens, provided by Spokane Public Schools. See SPS’s website for details.
              li
                strong Washington 211:
                |  Call 2-1-1 or (866) 904-9060 for referrals to food, housing, and emergency services.
              li
                strong Basic Food (SNAP):
                |  Apply for monthly food benefits at DSHS Basic Food. Eligibility based on income and household size.
            h3.mt-5 Other Basic Needs
            p.text-muted
              | Many food banks and pantries also provide clothing, hygiene products, and utility assistance. For a full directory of resources, visit the
              a(href='https://thefigtree.org', target='_blank') Fig Tree Resource Guide
              | .
            ul
              li
                strong Our Place Spokane:
                |  Food, clothing, hygiene, utility help, and bus passes at 1509 W College Ave.
              li
                strong Salvation Army:
                |  Emergency food, clothing, and community services at 204 E Indiana Ave.
              li
                strong Spokane Resource Center:
                |  Childcare, energy assistance, and wellness programs. See spokaneresourcecenter.org for details.
            h3.mt-5 Access & Support
            ul
              li Call Washington 211 at 2-1-1 or +1 (866) 904-9060 for immediate referrals to food and basic needs services.
              li Use the
                a(href='https://www.google.com/maps/d/u/0/viewer?mid=1QwQwQwQwQwQwQwQwQwQwQwQwQwQwQwQw&ll=47.6588%2C-117.4260&z=12', target='_blank') Spokane Resource Google Map
                |  to find food banks, meal sites, and more.
              li Visit
                a(href='https://www.dshs.wa.gov', target='_blank') dshs.wa.gov
                |  to apply for SNAP benefits.
    // Call to Action
    section.page-section.bg-primary.text-white.text-center
      .container.px-4.px-lg-5
        h2.mb-4 Need Food or Essentials Now?
        p.mb-4 Call Washington 211 or visit a local food bank for immediate help.
        a.btn.btn-light.btn-xl(href='index.html#contact') Contact Us 