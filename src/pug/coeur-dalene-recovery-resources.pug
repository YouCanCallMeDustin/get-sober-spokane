extends layout

block head
  - var canonicalUrl = 'https://www.getsoberspokane.com/coeur-dalene-recovery-resources.html'
  title Addiction Recovery Resources in Coeur d'Alene, ID | Get Sober Spokane
block meta
  meta(name="description" content="Free addiction recovery resources in Coeur d'Alene, ID. Find local treatment programs, sober living, food banks, and support groups on your journey to sobriety.")
  script(type="application/ld+json").
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Get Sober Spokane",
      "url": "https://www.getsoberspokane.com",
      "logo": "https://www.getsoberspokane.com/assets/img/logo.png",
      "telephone": "(509) 389-9350",
      "email": "getsoberspokane@outlook.com",
      "areaServed": {
        "@type": "City",
        "name": "Coeur d'Alene",
        "addressRegion": "ID"
      }
    }

block content

  header.bg-info.text-white.py-5(style="margin-top: 76px;")
    .container.px-4.px-lg-5
      .row.justify-content-center
        .col-lg-8.text-center
          h1.display-5.fw-bold Free Recovery Resources in Coeur d'Alene, ID
          p.lead.mt-3 Serving the Coeur d'Alene recovery community with free resources and support.

  section.page-section
    .container.px-4.px-lg-5
      .row.justify-content-center
        .col-lg-8
          p.lead.mt-4
            | Coeur d'Alene is part of the greater Spokane recovery community. Get Sober Spokane bridges the border to help CDA residents find addiction treatment, sober housing, and peer support — whether locally or just across the state line in Spokane.

          // Treatment Resources
          h2.mt-5
            i.bi.bi-heart-pulse.text-info.me-2
            | Treatment Resources
          p Access addiction treatment and counseling options in and near Coeur d'Alene, ID.
          ul
            li Kootenai Behavioral Health — Outpatient counseling and crisis services
            li Dirne Community Health Center — Low-cost primary care + substance use
            li Idaho CareLine: 211 (local referrals)
            li SAMHSA Helpline: 1-800-662-4357 (free, 24/7)
          a.btn.btn-outline-primary(href="/addiction-treatments-support.html" onclick="gtag('event', 'resources_click', {event_category: 'engagement', event_label: 'treatment_cda'})")
            i.bi.bi-arrow-right.me-2
            | Browse Treatment Programs

          // Shelter & Housing
          h2.mt-5
            i.bi.bi-house.text-info.me-2
            | Shelter &amp; Housing
          p Find sober living and emergency housing options in the Coeur d'Alene area.
          ul
            li The Gospel Mission of CDA — Emergency shelter and recovery programs
            li Blessings Under the Bridge — Immediate outreach for the homeless
            li North Idaho CARES — Housing and transitional support
          a.btn.btn-outline-primary(href="/shelter-housing.html" onclick="gtag('event', 'resources_click', {event_category: 'engagement', event_label: 'housing_cda'})")
            i.bi.bi-arrow-right.me-2
            | Find Housing Resources

          // Sober Activities
          h2.mt-5
            i.bi.bi-people.text-info.me-2
            | Sober Activities
          p Coeur d'Alene offers beautiful outdoor settings and a welcoming sober community.
          ul
            li CDA Lake Recreation — Hiking, paddling, and outdoor activities
            li CDA AA/NA Meetings — Daily meetings throughout the city
            li North Idaho Recovery Community Center — Peer support and events
          a.btn.btn-outline-primary(href="/community-engagement-sober-activities.html" onclick="gtag('event', 'resources_click', {event_category: 'engagement', event_label: 'activities_cda'})")
            i.bi.bi-arrow-right.me-2
            | Explore Sober Activities

          // Get Help Now
          .mt-5.p-4.bg-light.rounded-3
            h2.h4
              i.bi.bi-telephone-fill.text-danger.me-2
              | Get Help Now
            p If you or someone you know needs immediate help with addiction in Coeur d'Alene:
            ul.mb-3
              li
                strong Crisis Line:
                |  988 (Suicide &amp; Crisis Lifeline)
              li
                strong SAMHSA:
                |  1-800-662-4357
              li
                strong Local:
                |  (509) 389-9350
            a.btn.btn-primary.me-2(href="/resource-directory.html" onclick="gtag('event', 'resources_click', {event_category: 'engagement', event_label: 'all_resources_cda'})")
              i.bi.bi-list-ul.me-2
              | All Resources
            a.btn.btn-danger(href="tel:+19888" onclick="gtag('event', 'phone_click', {event_category: 'contact', event_label: '988_cda'})")
              i.bi.bi-telephone.me-2
              | Call 988
