extends layout.pug

block meta
    meta(name="description" content="Find 20+ free food banks, meal programs, and basic needs resources in Spokane, WA. Verified listings with addresses, hours, and eligibility requirements for groceries, hot meals, clothing, and hygiene products.")

    script(type="application/ld+json").
      {
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "name": "Food Banks & Basic Needs Assistance in Spokane, WA",
        "description": "Comprehensive directory of 20+ food banks, meal programs, and basic needs services in Spokane, WA. Free groceries, hot meals, clothing, and essential supplies.",
        "url": "https://www.getsoberspokane.com/food-basic-needs.html",
        "about": {
          "@type": "Thing",
          "name": "Food Security and Basic Needs Services"
        }
      }

block content
    //- Hero Section
    header.page-hero
      .container.px-4.px-lg-5
        h1 Food Banks & Basic Needs in Spokane, WA
        p.lead Free groceries, hot meals, clothing, and essential supplies for individuals and families.
        .hero-badges
          .hero-badge
            i.bi.bi-basket
            span 20+ Food Banks
          .hero-badge
            i.bi.bi-shield-heart
            span Verified Resources

    //- Main Content
    section.page-section
      .container.px-4.px-lg-5
        .row.justify-content-center
          .col-lg-10
            h2.text-primary.mt-0 Food Banks and Pantries in Spokane
            p Spokane is home to a comprehensive network of food banks and pantries that provide free groceries, fresh produce, and essential supplies. Many locations also offer clothing, hygiene products, utility assistance, and referrals to other social services.

            //- Major Food Banks Table
            .table-responsive
              table.table.table-bordered.table-striped.mt-3
                thead.table-dark
                  tr
                    th Organization
                    th Address
                    th Hours
                    th Services
                    th Requirements
                tbody
                  tr
                    td Second Harvest Food Bank of the Inland Northwest
                    td 1234 E Front Ave, Spokane, WA 99202
                    td Mon–Fri 8 AM – 4 PM
                    td Food distribution, nutrition education, SNAP assistance, mobile markets, Bite2Go
                    td Proof of income, photo ID
                  tr
                    td Serve Spokane Food Pantry
                    td 8303 B, N Division St, Spokane, WA 99208
                    td Thu 3–6 PM; 2nd & 4th Sat 9 AM – 12 PM
                    td Food distribution, clothing bank, household items, resource referrals
                    td Proof of address
                  tr
                    td Spokane Valley Partners – Food Bank
                    td 10814 E Broadway Ave, Spokane Valley, WA 99206
                    td Mon–Fri 9 AM – 3 PM
                    td Food distribution, mobile food bank, nutrition assistance, emergency social services
                    td Proof of address, income verification
                  tr
                    td The City Gate – Food & Clothing Bank
                    td 170 S Madison St, Spokane, WA 99201
                    td Tue–Fri 10 AM – 3 PM (food bank by appt)
                    td Food bank, clothing bank, hot meals (Wed/Fri/Sat 7 PM), spiritual support
                    td Appointment needed; zip codes 99201, 99204, 99224
                  tr
                    td Our Place Community Outreach
                    td 1509 W College Ave, Spokane, WA 99201
                    td Wed 3:30–6 PM; Thu 10 AM – 12:30 PM
                    td Food bank, hygiene products, bus passes (limited), utility assistance
                    td West Central residents, photo ID
                  tr
                    td MLK Community Center (East Central) Food Bank
                    td 500 S Stone St, Spokane, WA 99202
                    td Mon/Wed/Thu/Fri 10 AM–12 PM & 1–4:15 PM
                    td Food pantry, youth services, educational programs, senior support
                    td Zip code 99202 or 99212
                  tr
                    td The Salvation Army Spokane – Food Bank
                    td 204 E Indiana Ave, Spokane, WA 99207
                    td Mon–Fri 9–11:45 AM & 1–3 PM
                    td Emergency food boxes, case management, seasonal support, family services
                    td Photo ID, proof of address
                  tr
                    td Better Living Center – Seventh-day Adventist
                    td 25 E North Foothills Dr, Spokane, WA 99207
                    td Tue 9 AM – 4 PM; Thu 9 AM – 1 PM
                    td Food distribution, dietary education, personal care items
                    td Zip codes 99205, 99207, 99208
                  tr
                    td American Indian Community Center Food Bank
                    td 610 E North Foothills Dr, Spokane, WA 99207
                    td Wed–Fri 8:30 AM–12 PM & 1:30–4:30 PM; Tue 1:30–4:30 PM
                    td Food distribution, cultural support, social services, Native resources
                    td Native documentation or zip code 99202
                  tr
                    td Northeast Food Pantry (Northwest Connect)
                    td 4520 N Crestline St, Spokane, WA 99207
                    td Tue 11 AM – 1 PM; Thu 9–11 AM
                    td Food distribution, community connection, resource guides
                    td Northeast Spokane residents
                  tr
                    td North County Food Bank – Deer Park
                    td 109 E 3rd Ave, Deer Park, WA 99006
                    td Mon–Fri 9 AM – 3 PM
                    td Food distribution, emergency food, holiday baskets, local referrals
                    td Proof of address in North County
                  tr
                    td Mead Food Bank
                    td 12509 N Market St, Mead, WA 99021
                    td Wed 4–6:45 PM; Sun 4–5 PM
                    td Grocery assistance, emergency food bags, holiday support
                    td Mead district residency
                  tr
                    td Medical Lake Food Bank
                    td 207 S Washington St, Medical Lake, WA 99022
                    td Fri 10 AM – 12 PM; 1st Thu 5:30–6:30 PM
                    td Pantry distribution, senior boxes, emergency food
                    td Medical Lake area residency
                  tr
                    td Audubon Park UMC Food Bank
                    td 3908 N Driscoll Blvd, Spokane, WA 99205
                    td 2nd & 4th Tue 8:30–11:30 AM
                    td Food distribution, neighborly support
                    td Local neighborhood residency
                  tr
                    td Westminster Presbyterian Food Bank
                    td 2705 W Boone Ave, Spokane, WA 99201
                    td Mon & Fri 11 AM – 1:45 PM
                    td Pantry items, emergency food, pastoral care (optional)
                    td Zip code 99201 (North of River), photo ID
                  tr
                    td Otis Orchards Food Bank
                    td 4308 N Harvard Rd, Otis Orchards, WA 99027
                    td Tue 10 AM – 2 PM
                    td Grocery distribution, emergency food, community help
                    td Local residency

            //- Hot Meals & Special Programs
            h3.mt-5 Hot Meal Programs & Food Delivery
            p.text-muted Beyond food banks, Spokane offers free hot meals and home-delivered nutrition programs for vulnerable populations.

            .row.gx-4.gx-lg-5
              .col-md-6.mb-4
                .card.h-100.shadow-sm
                  .card-body
                    h5.card-title.text-primary.mb-2 Shalom Ministries – Dining with Dignity
                    p.card-text Free, nutritious meals in a dignified downtown environment. No judgment, just good food and community connection.
                    ul.mb-2
                      li Address: 518 W 3rd Ave, Spokane, WA 99201
                      li Breakfast: Mon–Thu 7:30–8:30 AM
                      li Lunch: Mon–Thu 11 AM – 12 PM
                      li Community Dinner: Mon 4 & 5 PM
                      li Open to anyone hungry (no weapons/drugs/alcohol)
                      li: a(href='https://shalomministries.org', target='_blank', rel='noopener') shalomministries.org
              .col-md-6.mb-4
                .card.h-100.shadow-sm
                  .card-body
                    h5.card-title.text-primary.mb-2 Meals on Wheels Greater Spokane County
                    p.card-text Home-delivered hot meals for seniors (60+) and homebound adults. Includes wellness checks and social contact.
                    ul.mb-2
                      li Phone: #[a(href='tel:+15094566597') (509) 456-6597]
                      li Deliveries: Mon–Fri Mid-day
                      li Requirement: Age 60+ or homebound with doctor note
                      li: a(href='https://mowgsc.org', target='_blank', rel='noopener') mowgsc.org
              .col-md-6.mb-4
                .card.h-100.shadow-sm
                  .card-body
                    h5.card-title.text-primary.mb-2 New Hope Ranch Food Ministry
                    p.card-text Community outreach providing regular food distribution and warm meals to Hillyard residents.
                    ul.mb-2
                      li Address: 2524 E Queen Ave, Spokane, WA 99217
                      li Hours: Mon & Wed 12–2 PM; Fri 5–6 PM
                      li Open to all
              .col-md-6.mb-4
                .card.h-100.shadow-sm
                  .card-body
                    h5.card-title.text-primary.mb-2 Spokane Humane Society Pet Food Pantry
                    p.card-text Helps keep pets with their families by providing free dog and cat food to owners in temporary financial need.
                    ul.mb-2
                      li Address: 6607 N Havana St, Spokane, WA 99217
                      li Phone: #[a(href='tel:+15094675235') (509) 467-5235]
                      li Hours: Tue–Sat 10:30 AM – 6 PM
                      li: a(href='https://spokanehumanesociety.org', target='_blank', rel='noopener') spokanehumanesociety.org

            //- Additional Resources
            h3.mt-5 Government Assistance & Additional Resources
            p.text-muted In addition to food banks, Spokane offers mobile meal programs and government assistance for food insecurity.
            ul
              li
                strong Second Harvest Mobile Market:
                |  Free produce, meats, and groceries at rotating locations. No appointment needed. Check their #[a(href='https://2-harvest.org', target='_blank', rel='noopener') website] for the next event.
              li
                strong Basic Food (SNAP):
                |  Apply for monthly food benefits at #[a(href='https://www.dshs.wa.gov', target='_blank', rel='noopener') DSHS Basic Food]. Eligibility based on income and household size.
              li
                strong Washington 211:
                |  Call #[a(href='tel:211') 2-1-1] or #[a(href='tel:+18669049060') (866) 904-9060] for referrals to food, housing, and emergency services.
              li
                strong Grad & Go Meals:
                |  Free grab-and-go meals for children and teens through Spokane Public Schools.

            h3.mt-5 Other Basic Needs
            p.text-muted Many food banks and community organizations also provide clothing, hygiene products, and utility assistance.
            ul
              li
                strong Our Place Spokane:
                |  Food, clothing, hygiene, utility help, and bus passes at 1509 W College Ave.
              li
                strong Salvation Army:
                |  Emergency food, clothing, and community services at 204 E Indiana Ave.
              li
                strong Spokane Resource Center:
                |  Childcare, energy assistance, and wellness programs at #[a(href='https://spokaneresourcecenter.org', target='_blank', rel='noopener') spokaneresourcecenter.org].

            h3.mt-5 Access & Support
            ul
              li Call Washington 2-1-1 at #[a(href='tel:211') 2-1-1] or #[a(href='tel:+18669049060') (866) 904-9060] for immediate referrals to food and basic needs services.
              li Visit #[a(href='https://www.dshs.wa.gov', target='_blank', rel='noopener') dshs.wa.gov] to apply for SNAP benefits.
              li Browse our full #[a(href='/resource-directory.html') Resource Directory] for all verified Spokane recovery resources.

    //- Call to Action
    section.page-section.bg-primary.text-white.text-center
      .container.px-4.px-lg-5
        h2.mb-4 Need Food or Essentials Now?
        p.mb-4 Call Washington 2-1-1 or visit a local food bank for immediate help.
        a.btn.btn-light.btn-xl(href='index.html#contact') Contact Us