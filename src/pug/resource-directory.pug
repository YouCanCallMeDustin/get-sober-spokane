            "numberOfItems": 6,
            "itemListElement": [
              {
                "@type": "ListItem",
                "position": 1,
                "name": "Shelter & Housing",
                "url": "https://www.getsoberspokane.com/shelter-housing.html"
              },
              {
                "@type": "ListItem",
                "position": 2,
                "name": "Food & Basic Needs",
                "url": "https://www.getsoberspokane.com/food-basic-needs.html"
              },
              {
                "@type": "ListItem",
                "position": 3,
                "name": "Addiction Treatment & Support",
                "url": "https://www.getsoberspokane.com/addiction-treatments-support.html"
              },
              {
                "@type": "ListItem",
                "position": 4,
                "name": "Mental Health & Medical Services",
                "url": "https://www.getsoberspokane.com/medical-mental-health.html"
              },
              {
                "@type": "ListItem",
