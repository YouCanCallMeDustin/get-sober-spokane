extends layout.pug

block content
    section.page-section
      // Top image
      .container-fluid.p-0
        img.img-fluid.w-100.mb-5.rounded.shadow(src='assets/img/13.jpg', alt='Community support at Get Sober Spokane', loading='lazy')
      .container.px-4.px-lg-5.text-center
        h2.mb-4.text-primary Support Get Sober Spokane
        p.lead.mb-5.text-muted
          | Your donation helps us provide vital resources and support to those in recovery in the Spokane community. Every contribution, no matter the size, makes a real difference.
        .row.justify-content-center.mb-5
          .col-lg-8
            .card.shadow.border-0.mb-4
              .card-body
                h3.h5.text-primary.mb-3 Why Donate to Get Sober Spokane?
                ul.text-start.list-unstyled.fs-5
                  li.mb-3
                    i.bi-check-circle-fill.text-success.me-2
                    | Directly supports individuals and families on their recovery journey
                  li.mb-3
                    i.bi-check-circle-fill.text-success.me-2
                    | Funds essential programs: shelter, food, mental health, and employment support
                  li.mb-3
                    i.bi-check-circle-fill.text-success.me-2
                    | Helps us host sober community events and outreach
                  li.mb-3
                    i.bi-check-circle-fill.text-success.me-2
                    | Enables us to provide free resources and referrals to those in need
                  li.mb-3
                    i.bi-check-circle-fill.text-success.me-2
                    | 100% of donations stay local to benefit the Spokane area
        .row.justify-content-center.mb-5
          .col-lg-8
            .bg-light.p-4.rounded.shadow-sm
              blockquote.mb-0
                p.text-secondary.mb-2
                  | "Get Sober Spokane gave me hope and a path forward when I needed it most. Your support truly changes lives."
                footer.blockquote-footer.mt-2
                  | — Grateful Community Member
        .row.justify-content-center
          .col-lg-8
            h4.text-primary Ready to Make a Difference?
            p.mb-4.text-muted
              | Your generosity fuels our mission. Thank you for helping us build a stronger, healthier Spokane.
            .row.g-3
              .col-md-6
                a.btn.btn-primary.btn-lg.w-100(href='https://paypal.me/SoberSpokane', target='_blank', rel='noopener' onclick="gtag('event', 'donate_click', {event_category: 'engagement', event_label: 'paypal'})")
                  i.bi-paypal.me-2
                  | PayPal
              .col-md-6
                a.btn.btn-success.btn-lg.w-100(href='https://cash.app/$SoberSpokane', target='_blank', rel='noopener' onclick="gtag('event', 'donate_click', {event_category: 'engagement', event_label: 'cashapp'})")
                  i.bi-cash-coin.me-2
                  | Cash App
            .mt-4
              .alert.alert-info
                h6.text-primary.mb-2
                  i.bi-info-circle.me-2
                  | How Your Donation Works
                p.small.mb-0
                  | All donations are transferred directly to our Chime account and used 100% for local Spokane recovery support. 
                  | We'll send you a receipt via email for your records.
      // Bottom image
      .container.px-4.px-lg-5.mt-5
        img.img-fluid.rounded.shadow-lg.mb-4(src='assets/img/14.jpg', alt='Get Sober Spokane community event', loading='lazy')
