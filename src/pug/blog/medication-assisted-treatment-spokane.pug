  script(type="application/ld+json").
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "MAT Clinics Spokane WA: The Ultimate Guide to Medication-Assisted Treatment",
      "description": "Looking for MAT clinics in Spokane WA? Discover the facts about Medication-Assisted Treatment, including Suboxone, Methadone, Vivitrol, and where to find local providers.",
      "url": "https://www.getsoberspokane.com/blog/medication-assisted-treatment-spokane.html",
      "datePublished": "2026-03-13",
      "dateModified": "2026-04-14",
      "author": {
        "@type": "Organization",
        "name": "Get Sober Spokane",
        "url": "https://www.getsoberspokane.com"
