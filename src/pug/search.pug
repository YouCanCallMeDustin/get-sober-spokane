extends layout.pug

block content
    // Search Header Section
    header.search-header.bg-primary.text-white.py-5.mt-5
        .container.px-4.px-lg-5
            .text-center
                h1.display-4.fw-bold Search Sober Spokane
                p.lead.opacity-75 Find resources, community members, and forum discussions
                .row.justify-content-center.mt-4
                    .col-lg-8
                        .search-box
                            .input-group.input-group-lg.shadow-sm
                                span.input-group-text.bg-white.border-end-0
                                    i.bi.bi-search.text-muted
                                input#globalSearchInput.form-control.border-start-0.py-3(type="text" placeholder="Start typing to search..." aria-label="Search" autofocus)
                                button#clearSearchBtn.btn.btn-white.border-start-0(type="button" style="display:none;")
                                    i.bi.bi-x-lg

    // Search Results Section
    section.search-results.py-5.bg-light
        .container.px-4.px-lg-5
            // Search Status
            .search-status.mb-4.text-center#searchStatus
                p.text-muted Type at least 2 characters to begin searching

            .row
                // Sidebar Filters (Optional but good for UX)
                .col-lg-3.mb-4
                    .sticky-top(style="top: 100px;")
                        .card.border-0.shadow-sm
                            .card-body
                                h5.card-title.mb-3 Categories
                                .list-group.list-group-flush#searchCategoryFilters
                                    a.list-group-item.list-group-item-action.d-flex.justify-content-between.align-items-center.active(href="#" data-filter="all")
                                        | All Results
                                        span.badge.bg-primary.rounded-pill#count-all 0
                                    a.list-group-item.list-group-item-action.d-flex.justify-content-between.align-items-center(href="#" data-filter="resources")
                                        | Resources
                                        span.badge.bg-secondary.rounded-pill#count-resources 0
                                    a.list-group-item.list-group-item-action.d-flex.justify-content-between.align-items-center(href="#" data-filter="forum")
                                        | Forum Posts
                                        span.badge.bg-secondary.rounded-pill#count-forum 0
                                    a.list-group-item.list-group-item-action.d-flex.justify-content-between.align-items-center(href="#" data-filter="members")
                                        | Members
                                        span.badge.bg-secondary.rounded-pill#count-members 0

                // Main Results Area
                .col-lg-9
                    #searchResultsContainer
                        // Initial state: empty or suggestions
                        .text-center.py-5.text-muted#noResultsPlaceholder
                            i.bi.bi-lightning-charge.fs-1.d-block.mb-3.opacity-25
                            p Enter a keyword to find what you're looking for.

                        // Dynamic Result Sections
                        section.results-section.mb-5#resourcesResultsSection(style="display:none;")
                            h4.border-bottom.pb-2.mb-3
                                i.bi.bi-list-ul.me-2.text-primary
                                | Resources
                            .row.g-4#resourcesResultsGrid
                        
                        section.results-section.mb-5#forumResultsSection(style="display:none;")
                            h4.border-bottom.pb-2.mb-3
                                i.bi.bi-chat-left-text.me-2.text-success
                                | Forum Discussions
                            .list-group.shadow-sm#forumResultsList

                        section.results-section.mb-5#membersResultsSection(style="display:none;")
                            h4.border-bottom.pb-2.mb-3
                                i.bi.bi-people.me-2.text-info
                                | Community Members
                            .row.g-3#membersResultsGrid

    // Custom Search Styles
    style.
        .search-header {
            background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
        }
        .search-box .input-group-text {
            border-radius: 10px 0 0 10px;
        }
        .search-box .form-control {
            border-radius: 0;
            font-size: 1.25rem;
        }
        .search-box .btn {
            border-radius: 0 10px 10px 0;
            background: white;
            border: 1px solid #ced4da;
            border-left: none;
        }
        .search-box .btn:hover {
            color: #dc3545;
        }
        .result-card {
            transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
            cursor: pointer;
        }
        .result-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }
        .highlight {
            background-color: #fff3cd;
            padding: 0 2px;
            border-radius: 2px;
            font-weight: bold;
        }
        .list-group-item.active {
            background-color: #4e73df;
            border-color: #4e73df;
        }

block scripts
    // Re-use Resource Directory for data
    script(src="js/resource-directory.js")
    // Main Search Logic
    script(src="js/search.js")
    // SimpleLightbox for potential images
    script(src='https://cdnjs.cloudflare.com/ajax/libs/SimpleLightbox/2.1.0/simpleLightbox.min.js')
    // Theme JS
    script(src="js/scripts.js")
