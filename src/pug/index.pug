extends layout.pug

block meta
    meta(name="description" content="Get Sober Spokane: Free local addiction recovery resources in Spokane, WA. Find AA/NA meetings, detox, and sober living to help you find your path to sobriety.")

    // Page specific preloads
    link(rel='preload', href='assets/img/bg-masthead.mp4', as='video', type='video/mp4')
    // SimpleLightbox plugin CSS
    link(href='https://cdnjs.cloudflare.com/ajax/libs/SimpleLightbox/2.1.0/simpleLightbox.min.css', rel='stylesheet')

block content
    // Masthead
    header.masthead
        // Video Background
        video#bgVideo.video-background(autoplay='', muted='', loop='', playsinline='', poster='assets/img/bg-masthead.webp')
            source(src='assets/img/bg-masthead.mp4', type='video/mp4')
            | Your browser does not support the video tag.
        .container.px-4.px-lg-5.h-100
            .row.gx-4.gx-lg-5.h-100.align-items-center.justify-content-center.text-center
                .col-lg-8.align-self-end
                    h1.text-white.font-weight-bold Supporting Recovery in Spokane
                    hr.divider
                .col-lg-8.align-self-baseline
                    p.text-white-75.mb-5
                        | A community dedicated to supporting individuals and families on their journey to sobriety and recovery. Find hope, connection, and resources in the Spokane area.
                    a.btn.btn-primary.btn-xl(href='#about') Learn More

    // About
    section#about.page-section.bg-primary
        .container.px-4.px-lg-5
            .row.gx-4.gx-lg-5.justify-content-center
                .col-lg-8.text-center
                    h2.text-white.mt-0 Supporting Your Recovery Journey
                    hr.divider.divider-light
                    p.text-white-75.mb-4
                        | Get Sober Spokane is committed to providing a safe, supportive environment for individuals seeking recovery from addiction. We believe in the power of community, connection, and hope in the healing process.
                    a.btn.btn-light.btn-xl(href='#services') Our Services

    // Services
    section#services.page-section
        .container.px-4.px-lg-5
            h2.text-center.mt-0 How We Support You
            hr.divider
            p.text-center.text-muted.mb-4 Click On Any Of The Categories Below
            .row.gx-4.gy-4
                .col-lg-4.col-md-6
                    a.glass-card.fade-in-up.svc-card-1(href='shelter-housing.html')
                        .icon-wrapper
                            i.bi-house-door
                        h3 Shelter and Housing
                        p Find safe, supportive shelter and housing resources in the Spokane area.
                .col-lg-4.col-md-6
                    a.glass-card.fade-in-up.svc-card-2(href='food-basic-needs.html')
                        .icon-wrapper
                            i.bi-bag-heart
                        h3 Food and Basic Needs
                        p Access food banks, clothing, hygiene supplies, and other essentials.
                .col-lg-4.col-md-6
                    a.glass-card.fade-in-up.svc-card-3(href='addiction-treatments-support.html')
                        .icon-wrapper
                            i.bi-capsule
                        h3 Treatment & Support
                        p Connect with treatment programs and peer-led support groups for recovery.
                .col-lg-4.col-md-6
                    a.glass-card.fade-in-up.svc-card-4(href='medical-mental-health.html')
                        .icon-wrapper
                            i.bi-heart-pulse
                        h3 Health Services
                        p Find mental health counseling, medical care, and wellness support.
                .col-lg-4.col-md-6
                    a.glass-card.fade-in-up.svc-card-5(href='employment-skills.html')
                        .icon-wrapper
                            i.bi-briefcase
                        h3 Employment & Skills
                        p Explore job training, employment services, and skill-building opportunities.
                .col-lg-4.col-md-6
                    a.glass-card.fade-in-up.svc-card-6(href='community-engagement-sober-activities.html')
                        .icon-wrapper
                            i.bi-people-fill
                        h3 Sober Activities
                        p Join sober events, volunteer, and connect with a supportive community.

    // Testimonials
    section#testimonials.page-section.bg-light
        .container.px-4.px-lg-5
            .text-center
                h2.mt-0 Recovery Stories from the Spokane Community
                hr.divider
                p.text-muted.mb-5 Real stories from real people on their journey to sobriety in Spokane, WA.
            .row.gx-4.gy-4
                .col-lg-4
                    .testimonial-card.fade-in-up.testi-card-1
                        i.bi.bi-quote.quote-icon
                        p.testimonial-text "Get Sober Spokane helped me find a sober living home within days of reaching out. I didn't know this many free resources existed in Spokane. It changed my life."
                        .author-info
                            .avatar
                                i.bi.bi-person-fill
                            .details
                                span.name Community Member
                                span.location Spokane, WA
                .col-lg-4
                    .testimonial-card.fade-in-up.testi-card-2
                        i.bi.bi-quote.quote-icon
                        p.testimonial-text "Finding my sponsor through this site was the turning point in my recovery. The process was simple and the match was perfect. I'm 14 months sober today."
                        .author-info
                            .avatar
                                i.bi.bi-person-fill
                            .details
                                span.name Community Member
                                span.location Spokane Valley, WA
                .col-lg-4
                    .testimonial-card.fade-in-up.testi-card-3
                        i.bi.bi-quote.quote-icon
                        p.testimonial-text "I was scared and didn't know where to start. The live chat gave me someone to talk to at 2am when I needed it most. This community is the real deal."
                        .author-info
                            .avatar
                                i.bi.bi-person-fill
                            .details
                                span.name Community Member
                                span.location North Spokane, WA
            .text-center.mt-4
                a.btn.btn-outline-primary.btn-xl(href='community-forum.html')
                    i.bi.bi-chat-left-text.me-2
                    | Share Your Story

    // Call to action
    section.cta-premium
        .container.px-4.px-lg-5.text-center.cta-content
            h2.mb-4.fade-in-up.cta-fade-1 Ready to Start Your Recovery Journey?
            .row.justify-content-center
                .col-lg-8
                    p.mb-4.fade-in-up.cta-fade-2 Join our supportive community and access comprehensive resources to help you on your path to recovery.
                    .row.g-3.fade-in-up.cta-fade-3
                        .col-md-4
                            a.btn.btn-light.btn-xl.w-100.cta-btn-premium(href='resource-directory.html' onclick="gtag('event', 'resources_click', {event_category: 'engagement'})")
                                i.bi.bi-search.me-2
                                | Browse Resources
                        .col-md-4
                            a.btn.btn-outline-light.btn-xl.w-100.cta-btn-premium(href='community-forum.html' onclick="gtag('event', 'community_click', {event_category: 'engagement'})")
                                i.bi.bi-people.me-2
                                | Join Community
                        //- .col-md-4
                        //-     a.btn.btn-outline-light.btn-xl.w-100.cta-btn-premium(href='dashboard.html')
                        //-         i.bi.bi-person.me-2
                        //-         | Your Dashboard

    // FAQ
    section#faq.page-section.bg-light
        .container.px-4.px-lg-5
            .row.gx-4.gx-lg-5.justify-content-center
                .col-lg-8.text-center
                    h2.mt-0 Frequently Asked Questions About Recovery in Spokane
                    hr.divider
                    p.text-muted.mb-5 Answers to the questions we hear most from people seeking help in Spokane and surrounding areas.
                .col-lg-8
                    .accordion#faqAccordion
                        .accordion-item.border-0.mb-3.shadow-sm(style="border-radius: 10px; overflow: hidden;")
                            h3.accordion-header#faq1heading
                                button.accordion-button.fw-semibold(
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faq1"
                                    aria-expanded="true"
                                    aria-controls="faq1"
                                ) How do I get started with addiction recovery in Spokane?
                            #faq1.accordion-collapse.collapse.show(aria-labelledby="faq1heading" data-bs-parent="#faqAccordion")
                                .accordion-body.text-muted The first step is reaching out. Get Sober Spokane offers a free resource directory, live community chat, and peer sponsor matching to help you take that first step at your own pace.
                        .accordion-item.border-0.mb-3.shadow-sm(style="border-radius: 10px; overflow: hidden;")
                            h3.accordion-header#faq2heading
                                button.accordion-button.collapsed.fw-semibold(
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faq2"
                                    aria-expanded="false"
                                    aria-controls="faq2"
                                ) Are all the resources on Get Sober Spokane free?
                            #faq2.accordion-collapse.collapse(aria-labelledby="faq2heading" data-bs-parent="#faqAccordion")
                                .accordion-body.text-muted Yes. Every resource listed on Get Sober Spokane is free to access. We are a community-run organization with no fees or commercial agenda.
                        .accordion-item.border-0.mb-3.shadow-sm(style="border-radius: 10px; overflow: hidden;")
                            h3.accordion-header#faq3heading
                                button.accordion-button.collapsed.fw-semibold(
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faq3"
                                    aria-expanded="false"
                                    aria-controls="faq3"
                                ) How do I find an AA or NA meeting in Spokane?
                            #faq3.accordion-collapse.collapse(aria-labelledby="faq3heading" data-bs-parent="#faqAccordion")
                                .accordion-body.text-muted You can browse our resource directory or visit our blog for a complete guide to AA and NA meetings across Spokane, Spokane Valley, and surrounding areas.
                        .accordion-item.border-0.mb-3.shadow-sm(style="border-radius: 10px; overflow: hidden;")
                            h3.accordion-header#faq4heading
                                button.accordion-button.collapsed.fw-semibold(
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faq4"
                                    aria-expanded="false"
                                    aria-controls="faq4"
                                ) Can I find a sober living home through Get Sober Spokane?
                            #faq4.accordion-collapse.collapse(aria-labelledby="faq4heading" data-bs-parent="#faqAccordion")
                                .accordion-body.text-muted Yes. Our shelter and housing page lists sober living homes and transitional housing options available in the Spokane area.
                        .accordion-item.border-0.mb-3.shadow-sm(style="border-radius: 10px; overflow: hidden;")
                            h3.accordion-header#faq5heading
                                button.accordion-button.collapsed.fw-semibold(
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faq5"
                                    aria-expanded="false"
                                    aria-controls="faq5"
                                ) How does the sponsor finder work?
                            #faq5.accordion-collapse.collapse(aria-labelledby="faq5heading" data-bs-parent="#faqAccordion")
                                .accordion-body.text-muted Our free sponsor finder connects people in recovery with experienced AA and NA sponsors in the Spokane area. Visit our sponsor finder page to get matched.
                        .accordion-item.border-0.shadow-sm(style="border-radius: 10px; overflow: hidden;")
                            h3.accordion-header#faq6heading
                                button.accordion-button.collapsed.fw-semibold(
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faq6"
                                    aria-expanded="false"
                                    aria-controls="faq6"
                                ) Is Get Sober Spokane only for people in Spokane?
                            #faq6.accordion-collapse.collapse(aria-labelledby="faq6heading" data-bs-parent="#faqAccordion")
                                .accordion-body.text-muted Our primary focus is Spokane and surrounding areas including Spokane Valley, Liberty Lake, and Coeur d'Alene, but anyone seeking recovery support is welcome in our community.

    // Contact
    section#contact.page-section
        .container.px-4.px-lg-5
            .row.gx-4.gx-lg-5.justify-content-center
                .col-lg-8.col-xl-6.text-center
                    h2.mt-0 Get In Touch
                    hr.divider
                    p.text-muted.mb-5
                        | Ready to take the first step? Contact us to learn more about our services and how we can support your recovery journey.
            .row.gx-4.gx-lg-5.justify-content-center
                .col-lg-4.text-center.mb-5.mb-lg-0
                    i.bi-phone.fs-2.mb-3.text-muted
                    div
                        a(href="tel:+15093899350" onclick="gtag('event', 'phone_click', {event_category: 'contact'})") (509) 389-9350
                    br
                    i.bi-envelope.fs-2.mb-3.text-muted
                    div
                        a(href='mailto:getsoberspokane@outlook.com' onclick="gtag('event', 'email_click', {event_category: 'contact'})") getsoberspokane@outlook.com
                    // Add more spacing below the email before the form
                    .mb-4
                    .mb-4
                    
                    // FAQ Structured Data (Bing/Copilot Grounding)
                    script(type="application/ld+json").
                        {
                            "@context": "https://schema.org",
                            "@type": "FAQPage",
                            "mainEntity": [
                                {
                                    "@type": "Question",
                                    "name": "How do I get started with addiction recovery in Spokane?",
                                    "acceptedAnswer": {
                                        "@type": "Answer",
                                        "text": "The first step is reaching out. Get Sober Spokane offers a free resource directory, live community chat, and peer sponsor matching to help you take that first step at your own pace."
                                    }
                                },
                                {
                                    "@type": "Question",
                                    "name": "Are all the resources on Get Sober Spokane free?",
                                    "acceptedAnswer": {
                                        "@type": "Answer",
                                        "text": "Yes. Every resource listed on Get Sober Spokane is free to access. We are a community-run organization with no fees or commercial agenda."
                                    }
                                },
                                {
                                    "@type": "Question",
                                    "name": "How do I find an AA or NA meeting in Spokane?",
                                    "acceptedAnswer": {
                                        "@type": "Answer",
                                        "text": "You can browse our resource directory or visit our blog for a complete guide to AA and NA meetings across Spokane, Spokane Valley, and surrounding areas."
                                    }
                                }
                            ]
                        }

                    form#contactForm(action='https://formspree.io/f/xvzwbkdv', method='POST')

                        // Name input
                        .form-floating.mb-3
                            input#name.form-control(
                                type='text',
                                name='name',
                                placeholder='Enter your name...',
                                required
                            )
                            label(for='name') Full name

                        // Email address input
                        .form-floating.mb-3
                            input#email.form-control(
                                type='email',
                                name='email',
                                placeholder='name@example.com',
                                required
                            )
                            label(for='email') Email address

                        // Phone number input
                        .form-floating.mb-3
                            input#phone.form-control(
                                type='tel',
                                name='phone',
                                placeholder='(123) 456-7890',
                                required
                            )
                            label(for='phone') Phone number

                        // Message input
                        .form-floating.mb-3
                            textarea#message.form-control(
                                name='message',
                                placeholder='Enter your message here...',
                                style='height: 10rem;',
                                required
                            )
                            label(for='message') Message

                        // Submit Button
                        .d-grid
                            button#submitButton.btn.btn-primary.btn-xl(type='submit') Send Message

block scripts
    // SimpleLightbox plugin JS
    script(src='https://cdnjs.cloudflare.com/ajax/libs/SimpleLightbox/2.1.0/simpleLightbox.min.js')
    // Core theme JS
    script(src='js/scripts.js')
    // Page specific initialization
    script.
        document.addEventListener('DOMContentLoaded', function() {
          // Initialize Lightbox if needed
          if (typeof SimpleLightbox !== 'undefined') {
            new SimpleLightbox('.portfolio-box', { /* options */ });
          }
        });
