        // FAQPage Structured Data
        script(type='application/ld+json').
            {
                "@context": "https://schema.org",
                "@type": "FAQPage",
                "mainEntity": [
                    {
                        "@type": "Question",
                        "name": "How do I get started with addiction recovery in Spokane?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "The first step is reaching out. Get Sober Spokane offers a free resource directory, live community chat, and peer sponsor matching to help you take that first step at your own pace."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "Are all the resources on Get Sober Spokane free?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "Yes. Every resource listed on Get Sober Spokane is free to access. We are a community-run organization with no fees or commercial agenda."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "How do I find an AA or NA meeting in Spokane?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "You can browse our resource directory or visit our blog for a complete guide to AA and NA meetings across Spokane, Spokane Valley, and surrounding areas."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "Can I find a sober living home through Get Sober Spokane?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "Yes. Our shelter and housing page lists sober living homes and transitional housing options available in the Spokane area."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "How does the sponsor finder work?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "Our free sponsor finder connects people in recovery with experienced AA and NA sponsors in the Spokane area. Visit our sponsor finder page to get matched."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "Is Get Sober Spokane only for people in Spokane?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "Our primary focus is Spokane and surrounding areas including Spokane Valley, Liberty Lake, and Coeur d'Alene, but anyone seeking recovery support is welcome in our community."
                        }
                    }
                ]
            }

